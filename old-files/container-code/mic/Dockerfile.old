FROM mcr.microsoft.com/azurelinux/base/core:3.0

WORKDIR /app

# Install system dependencies for audio and compilation
RUN ln -sf /usr/bin/tdnf /usr/bin/dnf \
    && dnf -y makecache \
    && dnf -y update \
    && dnf -y install \
    python3 \
    python3-pip \
    alsa-utils \
    alsa-lib-devel \
    libsndfile \
    libsndfile-devel \
    gcc \
    gcc-c++ \
    make \
    && dnf clean all

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# Copy the application
COPY access_mic.py .

# Run the application
CMD ["python3", "access_mic.py"]
